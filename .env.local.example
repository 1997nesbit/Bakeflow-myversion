# ─── Bakeflow Frontend — Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in the values for your environment.
# .env.local is gitignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Django backend base URL (no trailing slash)
# Development:  http://localhost:8000/api
# Production:   https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# App display name (used in page titles / meta)
NEXT_PUBLIC_APP_NAME=Bakeflow

# Currency code displayed in the UI
NEXT_PUBLIC_CURRENCY=TZS

# JWT token expiry awareness (minutes) — should match Django simplejwt ACCESS_TOKEN_LIFETIME
NEXT_PUBLIC_TOKEN_EXPIRY_MINUTES=15
