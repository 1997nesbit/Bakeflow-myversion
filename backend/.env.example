# Copy this file to .env and fill in your values.
# Never commit .env to git.

SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True

# Postgres — create these in pgAdmin first
DB_NAME=bakeflow_dev
DB_USER=bakeflow_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS — add more origins as comma-separated values
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Dev superuser — created automatically on startup if no superuser exists
DJANGO_SUPERUSER_EMAIL=admin@bakeflow.dev
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_NAME=Admin
DJANGO_SUPERUSER_PHONE=0700000000
